<?xml version="1.0" encoding="utf-8"?>
<!--
  Network Security Configuration for Thanni Canuuu
  Allows cleartext HTTP for development (localhost/10.0.2.2)
  and your production server. Remove cleartext for production if using HTTPS.
-->
<network-security-config>
    <!-- Allow cleartext for Capacitor localhost (WebView origin) -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">localhost</domain>
        <domain includeSubdomains="true">10.0.2.2</domain>
        <!-- Add your production server IP/domain here -->
        <!-- <domain includeSubdomains="true">yourdomain.com</domain> -->
    </domain-config>
</network-security-config>
